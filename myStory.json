{
    "Title": "Space thingy",
    "Credits": "Created by Tyler Roth (tdroth@ucsc.edu).",
    "InitialLocation": "Start",
    "Locations": {
        "Start": {
            "Body": "You wake up to a loud BANG and low pressure alarms. The walls of the lunar base have given way, and air is rushing out quickly! Thinking fast, you make your way to the airlock and put on your EVA suit. The base's air pressure won't last for long, and neither will your suit's oxygen for much time afterwards.",
            "Choices": [
                {
                    "Text": "Examine your surroundings",
                    "Target": "AirlockRoom"
                }
            ]
        },

        "AirlockRoom": {
            "Body": "You are in the airlock room, the exit to the interior portion of the colony. A hole larger than your fist has formed from a tear in the wall. You can still feel some of the thin leftover air rushing out. A row of EVA suits lines the wall.",
            "BodyVisited": "You are in the airlock room.",
            "Choices": [
                {
                    "Text": "EVA Suits (North)",
                    "Target": "EVASuits"
                },
                {
                    "Text": "Main Room (East)",
                    "Target": "MainRoom"
                },
                {
                    "Text": "Exit (West)",
                    "Target": "Exit"
                }
            ]
        },

        "EVASuits": {
            "Body": "Only spare EVA suits are left. The rest of your crewmates took a rover to the nearby colony, leaving you alone to manage the base.",
            "Choices": [
                {
                    "Text": "Airlock Room (South)",
                    "Target": "AirlockRoom"
                }
            ]
        },

        "Exit": {
            "Body": "The wall failure cut the power to the airlock, you will need to force it open.. somehow.",
            "Choices": [
                {
                    "Text": "Airlock Room (East)",
                    "Target": "AirlockRoom"
                },
                {
                    "Text": "Open Airlock (East)",
                    "Target": "Outside",
                    "ReqFlag": "CaptainNote",
                    "ReqFlagValue": "true"
                }
            ]
        },

        "Outside": {
            "Body": "You finally manage to get the airlock open, and step foot into the crater your base was dug into. You spot a concrete pad with a rover on it.",
            "Choices": [
                {
                    "Text": "Enter the Rover",
                    "Target": "Rover"
                }
            ]
        },

        "Rover": {
            "Body": "You start driving away from the base, hopefully to rendevous with the rest of your crew and let them know what happend."
        },

        "MainRoom": {
            "Body": "The main room of the colony. It has a table for meetings and meals, a calender for scheduling, and various items scattered across the room.",
            "Choices": [
                {
                    "Text": "Bedroom (North)",
                    "Target": "Bedroom"
                },
                {
                    "Text": "Lab (South)",
                    "Target": "Lab"
                },
                {
                    "Text": "Gym (East)",
                    "Target": "Gym"
                },
                {
                    "Text": "Airlock (West)",
                    "Target": "AirlockRoom"
                }
            ]
        },

        "Bedroom": {
            "Body": "A bedroom housing all of the base's inhabitants.",
            "Choices": [
                {
                    "Text": "Bathroom (North)",
                    "Target": "Bathroom"
                },
                {
                    "Text": "Main Room (South)",
                    "Target": "MainRoom"
                },
                {
                    "Text": "Storage Room (East)",
                    "Target": "StorageRoom"
                },
                {
                    "Text": "Lockers (West)",
                    "Target": "Lockers"
                }
            ]
        },

        "Lockers": {
            "Body": "A wall of lockers, one for each base member.",
            "Choices": [
                {
                    "Text": "Bedroom (East)",
                    "Target": "Bedroom"
                },
                {
                    "Text": "Rummage through the captain's locker",
                    "Target": "CaptainLocker",
                    "SetFlag": "CaptainNote",
                    "SetFlagValue": "true",
                    "ReqFlag": "CaptainNote",
                    "ReqFlagValue": "null"
                }
            ]
        },

        "CaptainLocker": {
            "Body": "You find a note which shows how to open the airlock manually.",
            "Choices": [
                {
                    "Text": "Back",
                    "Target": "Lockers"
                }
            ]
        },

        "Bathroom": {
            "Body": "A bathroom. There's a toilet and a sink.",
            "Choices": [
                {
                    "Text": "Bedroom (South)",
                    "Target": "Bedroom"
                }
            ]
        },

        "StorageRoom": {
            "Body": "A storage room. There are containers full of rations, tools, and miscellaneous supplies.",
            "Choices": [
                {
                    "Text": "Gym (South)",
                    "Target": "Gym"
                },
                {
                    "Text": "Bedroom (West)",
                    "Target": "Bedroom"
                }
            ]
        },

        "Gym": {
            "Body": "A room full of special low gravity exercise machines.",
            "Choices": [
                {
                    "Text": "Storage Room (North)",
                    "Target": "StorageRoom"
                },
                {
                    "Text": "Main Room (West)",
                    "Target": "MainRoom"
                }
            ]
        },

        "Lab": {
            "Body": "A fancy laboratory. There are tables with petri dishes growing bacteria, low gravity plant experiments, a pool of algae, and other experiments.",
            "Choices": [
                {
                    "Text": "Main Room (North)",
                    "Target": "MainRoom"
                },
                {
                    "Text": "Hydroponics (East)",
                    "Target": "Hydroponics"
                }
            ]
        },

        "Hydroponics": {
            "Body": "A rooms filled to the brim with shelves of plants.",
            "Choices": [
                {
                    "Text": "Lab (West)",
                    "Target": "Lab"
                }
            ]
        }
    }
